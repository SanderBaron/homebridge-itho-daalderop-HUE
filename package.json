{
  "displayName": "Homebridge Itho Daalderop",
  "name": "homebridge-itho-daalderop-hue",
  "version": "2.0.0",
  "description": "Homebridge plugin for Itho Daalderop mechanical ventilation with WiFi add-on. Fan control, sensor readings, humidity automation and time scheduling in Apple HomeKit.",
  "license": "MIT",
  "author": {
    "name": "Sander Baron",
    "url": "https://github.com/SanderBaron"
  },
  "contributors": [
    {
      "name": "Jordy van den Aardweg",
      "url": "https://github.com/jvandenaardweg"
    }
  ],
  "homepage": "https://github.com/SanderBaron/homebridge-itho-daalderop-HUE#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanderBaron/homebridge-itho-daalderop-HUE.git"
  },
  "bugs": {
    "url": "https://github.com/SanderBaron/homebridge-itho-daalderop-HUE/issues"
  },
  "engines": {
    "node": ">=18.15.0",
    "homebridge": ">=2.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "customUi": true,
  "files": [
    "dist",
    "homebridge-ui",
    "config.schema.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint src/**.ts --max-warnings=0",
    "watch": "npm run build && npm link && nodemon",
    "prebuild": "node -p \"'export const PLUGIN_VERSION = ' + JSON.stringify(require('./package.json').version) + ';'\" > src/version.ts",
    "build": "rimraf ./dist && tsc --project tsconfig.build.json && resolve-tspaths",
    "prepublishOnly": "npm run lint && npm run build",
    "pretest": "npm run lint && npm run type-check",
    "set-version": "npm run prebuild",
    "homebridge": "homebridge -D",
    "update": "npx npm-check-updates --interactive",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "release": "dotenv npx release-it",
    "type-check": "tsc --noEmit",
    "prepare": "is-ci || husky install",
    "lint-staged": "lint-staged"
  },
  "keywords": [
    "apple",
    "homebridge",
    "homebridge-plugin",
    "homebridge plugin",
    "homekit",
    "homekit-accessory",
    "apple-homekit",
    "apple homekit",
    "homebridge-plugins",
    "itho",
    "itho-daalderop",
    "itho daalderop",
    "ventilation",
    "mechanical ventilation",
    "humidity",
    "automation",
    "co2",
    "hue"
  ],
  "devDependencies": {
    "@homebridge/hap-nodejs": "^2.1.7",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-istanbul": "^1.6.0",
    "dotenv-cli": "^7.4.2",
    "eslint": "^8.57.0",
    "homebridge": "^2.1.0",
    "husky": "^8.0.3",
    "is-ci": "^3.0.1",
    "lint-staged": "^15.2.7",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "release-it": "^17.4.0",
    "resolve-tspaths": "^0.8.22",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.0.0",
    "mqtt": "^5.10.1",
    "undici": "^8.4.1",
    "zod": "^3.23.8"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release v${version}",
      "changelog": "npx auto-changelog --stdout --commit-limit false --unreleased --template https://raw.githubusercontent.com/release-it/release-it/master/templates/changelog-compact.hbs"
    },
    "hooks": {
      "after:bump": "npx auto-changelog -p --commit-limit false && npm run set-version"
    },
    "npm": {
      "publish": false
    },
    "github": {
      "release": true,
      "releaseName": "v${version}"
    }
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write"
    ],
    "*.js": [
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "precommit": "lint-staged"
    }
  }
}
