{
  "pluginAlias": "HomebridgeIthoDaalderop",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "headerDisplay": "Control your Itho Daalderop mechanical ventilation via the WiFi add-on module. [Read the README](https://github.com/SanderBaron/homebridge-itho-daalderop-HUE#readme) for setup instructions.",

  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "Itho Daalderop",
        "placeholder": "Itho Daalderop"
      },
      "verboseLogging": {
        "title": "Verbose logging",
        "type": "boolean",
        "required": false,
        "default": false
      },

      "device": {
        "type": "object",
        "properties": {
          "co2Sensor": {
            "title": "Built-in CO₂ sensor",
            "type": "boolean",
            "required": false,
            "default": false
          },
          "nonCve": {
            "title": "Non-CVE device (HRU-350, DemandFlow, QualityFlow or HRU Eco Fan)",
            "type": "boolean",
            "default": false
          }
        }
      },

      "api": {
        "type": "object",
        "properties": {
          "protocol": {
            "title": "Protocol",
            "type": "string",
            "required": true,
            "default": "mqtt",
            "oneOf": [
              { "title": "MQTT (recommended)", "enum": ["mqtt"] },
              { "title": "HTTP (polling)", "enum": ["http"] }
            ]
          },
          "ip": {
            "type": "string",
            "title": "IP address",
            "required": true,
            "placeholder": "192.168.1.10",
            "format": "ipv4",
            "description": "MQTT broker IP (e.g. Mac Mini running Mosquitto) when using MQTT. Itho device IP when using HTTP."
          },
          "port": {
            "type": "number",
            "title": "Port",
            "required": true,
            "placeholder": "1883"
          },
          "deviceIp": {
            "type": "string",
            "title": "Itho device IP (for dashboard)",
            "format": "ipv4",
            "placeholder": "192.168.1.82",
            "description": "Optional. Only needed when using MQTT and you want the live status dashboard to read directly from the Itho module."
          },
          "username": {
            "type": "string",
            "title": "MQTT gebruikersnaam",
            "required": false,
            "placeholder": "Optioneel"
          },
          "password": {
            "type": "string",
            "title": "MQTT wachtwoord",
            "required": false,
            "placeholder": "Optioneel"
          },
          "deviceUsername": {
            "type": "string",
            "title": "NRGWatch gebruikersnaam",
            "required": false,
            "placeholder": "Optioneel",
            "description": "Inloggegevens voor de NRGWatch webinterface (alleen invullen als authenticatie is ingeschakeld op het apparaat)."
          },
          "devicePassword": {
            "type": "string",
            "title": "NRGWatch wachtwoord",
            "required": false,
            "placeholder": "Optioneel"
          }
        }
      },

      "hue": {
        "type": "object",
        "properties": {
          "bridgeIp": {
            "type": "string",
            "title": "Hue Bridge IP-adres",
            "format": "ipv4",
            "placeholder": "192.168.1.16",
            "description": "IP-adres van de Philips Hue Bridge (Phase 2)."
          },
          "apiKey": {
            "type": "string",
            "title": "Hue API sleutel",
            "placeholder": "xxxxxxxxxxxxxxxxxx",
            "description": "API-sleutel voor de Hue Bridge. Te vinden via de Hue API of Homebridge Hue-plugin."
          }
        }
      },

      "automation": {
        "type": "object",
        "properties": {
          "turbo": {
            "type": "object",
            "properties": {
              "durationMinutes": {
                "title": "Turbo duration (min)",
                "type": "number",
                "default": 20,
                "minimum": 1,
                "maximum": 120,
                "description": "How many minutes the Turbo switch runs at high speed before automatically returning to auto mode."
              }
            }
          },
          "humidity": {
            "type": "object",
            "properties": {
              "enabled": {
                "title": "Vochtigheidsautomaat inschakelen",
                "type": "boolean",
                "default": true
              },
              "mode": {
                "title": "Sensormodus",
                "type": "string",
                "default": "badkamer",
                "oneOf": [
                  { "title": "Badkamer (absolute + snelle stijging + cooldown)", "enum": ["badkamer"] },
                  { "title": "Wasruimte (drie drempelzones, geen cooldown)", "enum": ["wasruimte"] }
                ]
              },
              "boostThreshold": {
                "title": "Absolute drempel (%)",
                "type": "number",
                "default": 85,
                "minimum": 50,
                "maximum": 100,
                "description": "Ventilator naar HIGH zodra deze waarde bereikt wordt. Itho spec: 85% badkamer, 90% wasruimte."
              },
              "dropThreshold": {
                "title": "Terugkeerdrempel (%)",
                "type": "number",
                "default": 82,
                "minimum": 40,
                "maximum": 95,
                "description": "Cooldown-timer mag pas eindigen als vochtigheid onder deze waarde ligt. Itho spec: 82% badkamer."
              },
              "cooldownMinutes": {
                "title": "Minimale cooldown (min)",
                "type": "number",
                "default": 20,
                "minimum": 1,
                "maximum": 120,
                "description": "Minimale tijd dat de ventilator op HIGH blijft nadat de vochtigheid daalt. Langer douchen? Geen probleem — ventilator blijft aan tot de vochtigheid echt gezakt is."
              },
              "riseRate": {
                "title": "Snelle stijging drempel (%)",
                "type": "number",
                "default": 3,
                "minimum": 0,
                "maximum": 20,
                "description": "Boost triggert ook bij een stijging van dit % binnen het detectievenster. Stel in op 0 om uit te schakelen. Itho spec: 3%."
              },
              "riseWindowSeconds": {
                "title": "Detectievenster (seconden)",
                "type": "number",
                "default": 24,
                "minimum": 5,
                "maximum": 120,
                "description": "Tijdvenster voor snelle stijging. Itho spec: 24 of 48 seconden."
              },
              "minSpeedThreshold": {
                "title": "Minimum-stand drempel (%, alleen wasruimte)",
                "type": "number",
                "default": 75,
                "minimum": 40,
                "maximum": 85,
                "description": "Alleen wasruimte-modus: onder deze waarde gaat de ventilator naar de minimumstand."
              },
              "manualOverrideMinutes": {
                "title": "Override-pauze na handmatige bediening (min)",
                "type": "number",
                "default": 60,
                "minimum": 0,
                "maximum": 240
              }
            }
          },
          "mirrorHeater": {
            "type": "object",
            "properties": {
              "enabled": {
                "title": "Spiegelverwarming inschakelen",
                "type": "boolean",
                "default": false
              },
              "hueLightId": {
                "title": "Hue lamp-ID (spiegel)",
                "type": "string",
                "placeholder": "bijv. 5 of een UUID",
                "description": "ID van de Hue-lamp die de spiegelverwarming aanstuurt."
              },
              "durationMinutes": {
                "title": "Brandtijd spiegel (min)",
                "type": "number",
                "default": 30,
                "minimum": 1,
                "maximum": 120,
                "description": "Hoelang de spiegelverwarming aan blijft nadat de vochtigheid daalt."
              }
            }
          },
          "toiletLight": {
            "type": "object",
            "properties": {
              "enabled": {
                "title": "Toilet-detectie inschakelen",
                "type": "boolean",
                "default": false
              },
              "hueSensorId": {
                "title": "Hue sensor/knop ID (toilet)",
                "type": "string",
                "placeholder": "bijv. 12 of een UUID",
                "description": "ID van de Hue-schakelaar of -sensor die het toiletlicht detecteert."
              },
              "minOnMinutes": {
                "title": "Minimale brandduur licht (min)",
                "type": "number",
                "default": 2,
                "minimum": 1,
                "maximum": 30,
                "description": "Het licht moet minimaal zo lang aan zijn geweest om de CVE-boost te activeren."
              },
              "boostMinutes": {
                "title": "CVE boost-duur (min)",
                "type": "number",
                "default": 20,
                "minimum": 1,
                "maximum": 120,
                "description": "Hoelang de CVE op maximale stand draait na detectie."
              }
            }
          },
          "schedule": {
            "type": "object",
            "properties": {
              "enabled": {
                "title": "Enable schedule",
                "type": "boolean",
                "default": false
              },
              "entries": {
                "title": "Schedule entries",
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "label": {
                      "title": "Label",
                      "type": "string",
                      "placeholder": "Morning airing",
                      "required": true
                    },
                    "days": {
                      "title": "Days",
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
                      },
                      "uniqueItems": true
                    },
                    "from": {
                      "title": "From (HH:MM)",
                      "type": "string",
                      "placeholder": "07:00",
                      "required": true
                    },
                    "to": {
                      "title": "To (HH:MM)",
                      "type": "string",
                      "placeholder": "08:00",
                      "required": true
                    },
                    "speed": {
                      "title": "Fan speed",
                      "type": "string",
                      "required": true,
                      "oneOf": [
                        { "title": "Low", "enum": ["low"] },
                        { "title": "Medium", "enum": ["medium"] },
                        { "title": "High", "enum": ["high"] }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },

  "layout": [
    {
      "type": "flex",
      "flex-flow": "row wrap",
      "items": [{ "key": "name" }]
    },

    {
      "type": "fieldset",
      "title": "Device type",
      "expandable": true,
      "expanded": false,
      "items": [
        {
          "key": "device.co2Sensor",
          "description": "Enable if your CVE unit has a built-in CO₂ sensor. The plugin will use virtual remote commands (low/medium/high) instead of raw speed values."
        },
        {
          "key": "device.nonCve",
          "description": "Enable for HRU-350, DemandFlow, QualityFlow or HRU Eco Fan."
        }
      ]
    },

    {
      "type": "fieldset",
      "title": "Connection",
      "expandable": false,
      "items": [
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "api.protocol" },
            { "key": "api.ip" },
            { "key": "api.port" }
          ]
        },
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "api.deviceIp" }
          ]
        },
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "api.username" },
            { "key": "api.password" }
          ]
        },
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "api.deviceUsername" },
            { "key": "api.devicePassword" }
          ]
        },
        { "key": "verboseLogging" }
      ]
    },

    {
      "type": "fieldset",
      "title": "Turbo mode",
      "description": "The Turbo switch in HomeKit runs the fan at full speed for a set time, then automatically returns to auto mode.",
      "expandable": true,
      "expanded": true,
      "items": [
        { "key": "automation.turbo.durationMinutes" }
      ]
    },

    {
      "type": "fieldset",
      "title": "Humidity automation",
      "description": "Automatically boost fan speed when shower humidity is detected on the internal exhaust sensor. Humidity is measured in the exhaust duct so it reacts quickly.",
      "expandable": true,
      "expanded": true,
      "items": [
        { "key": "automation.humidity.enabled" },
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "automation.humidity.boostThreshold", "description": "Fan goes to HIGH when this % is reached." },
            { "key": "automation.humidity.dropThreshold", "description": "Cooldown timer starts when humidity drops below this %." }
          ]
        },
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "automation.humidity.cooldownMinutes", "description": "Minutes to keep running HIGH after humidity drops, before returning to auto." },
            { "key": "automation.humidity.manualOverrideMinutes", "description": "After a manual speed change, automation is paused this many minutes." }
          ]
        }
      ]
    },

    {
      "type": "fieldset",
      "title": "Tijdschema-overrides",
      "description": "Overschrijf de ventilatorstand tijdens bepaalde tijdvensters — bijv. 's ochtends luchten. De vochtigheidsautomaat heeft hogere prioriteit dan het schema.",
      "expandable": true,
      "expanded": false,
      "items": [
        { "key": "automation.schedule.enabled" },
        {
          "key": "automation.schedule.entries",
          "type": "array",
          "items": [
            { "key": "automation.schedule.entries[].label" },
            {
              "type": "flex",
              "flex-flow": "row wrap",
              "items": [
                { "key": "automation.schedule.entries[].from" },
                { "key": "automation.schedule.entries[].to" },
                { "key": "automation.schedule.entries[].speed" }
              ]
            },
            {
              "key": "automation.schedule.entries[].days",
              "type": "checkboxes",
              "titleMap": {
                "mon": "Ma", "tue": "Di", "wed": "Wo", "thu": "Do",
                "fri": "Vr", "sat": "Za", "sun": "Zo"
              }
            }
          ]
        }
      ]
    },

    {
      "type": "fieldset",
      "title": "Philips Hue (Phase 2)",
      "description": "Koppeling met Philips Hue Bridge voor spiegelverwarming en toilet-detectie. Hardware nog niet vereist — vul alvast in als je de Hue Bridge al hebt.",
      "expandable": true,
      "expanded": false,
      "items": [
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "hue.bridgeIp" },
            { "key": "hue.apiKey" }
          ]
        }
      ]
    },

    {
      "type": "fieldset",
      "title": "Spiegelverwarming (Phase 2 — Hue)",
      "description": "Stuurt een Hue-lamp (spiegelverwarming) aan op basis van de vochtigheid in de badkamer. Vereist Hue Bridge-koppeling hierboven.",
      "expandable": true,
      "expanded": false,
      "items": [
        { "key": "automation.mirrorHeater.enabled" },
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "automation.mirrorHeater.hueLightId" },
            { "key": "automation.mirrorHeater.durationMinutes" }
          ]
        }
      ]
    },

    {
      "type": "fieldset",
      "title": "Toilet-ventilatie (Phase 2 — Hue)",
      "description": "Detecteert het toiletlicht via een Hue-schakelaar of -sensor en stuurt de CVE aan. Als het licht langer aan is dan de drempel, gaat de ventilator op maximum.",
      "expandable": true,
      "expanded": false,
      "items": [
        { "key": "automation.toiletLight.enabled" },
        {
          "type": "flex",
          "flex-flow": "row wrap",
          "items": [
            { "key": "automation.toiletLight.hueSensorId" },
            { "key": "automation.toiletLight.minOnMinutes" },
            { "key": "automation.toiletLight.boostMinutes" }
          ]
        }
      ]
    }
  ]
}
